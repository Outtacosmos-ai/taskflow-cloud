# ─── AWS ──────────────────────────────────────────────────────────────────────
AWS_REGION=us-east-1
# Leave blank when running on EC2/ECS with an IAM role
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=

# ─── SQS ──────────────────────────────────────────────────────────────────────
SQS_QUEUE_URL=https://sqs.us-east-1.amazonaws.com/123456789012/taskflow-notifications
SQS_VISIBILITY_TIMEOUT=30
SQS_WAIT_TIME_SECONDS=20
SQS_MAX_MESSAGES=10

# ─── Email (SMTP) ─────────────────────────────────────────────────────────────
SMTP_HOST=smtp.example.com
SMTP_PORT=587
SMTP_USER=notifications@example.com
SMTP_PASS=change_me
EMAIL_FROM="TaskFlow Cloud <notifications@example.com>"
